<% content_for :title, "#{@user.username}'s Profile" %>

<h1><%= @user.username %>'s Profile</h1>

<div class="user-info">
  <p><strong>Email:</strong> <%= @user.email %></p>
  <p><strong>Joined:</strong> <%= @user.created_at.strftime("%B %d, %Y") %></p>
  <p><strong>Total Posts:</strong> <%= @user.posts.count %></p>
</div>

<section class="danger-zone">
  <h2>Delete account</h2>
  <p>This permanently deletes your account and all <%= pluralize(@user.posts.count, "post") %>. This can't be undone.</p>
  <%= button_to "Delete account and all posts", user_path(@user),
        method: :delete,
        class: "btn btn-danger",
        data: { turbo_confirm: "Delete your account and all your posts? This can't be undone." } %>
</section>
